<?xml version="1.0" encoding="UTF-8"?>
<!--
  Nyro AppStream Metadata
  Place this file at: linux/packaging/myappid.appdata.xml
-->
<component type="desktop-application">
  <id>app.nyro.lol</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Nyro</name>
  <summary>Modern proxy and VPN client for Linux</summary>

  <developer_name>Nyro</developer_name>
  <update_contact>linux@nyro.lol</update_contact>

  <description>
    <p>
      Nyro is an advanced proxy and VPN client built for privacy and control.
      It is based on Hiddify App and powered by Hiddify Core and Sing-box.
      It supports multiple backend protocols including V2Ray, Xray, Clash, and Sing-box,
      providing flexibility and performance for all kinds of network configurations.
    </p>
    <p>
      Designed with simplicity in mind, Nyro helps users connect securely and
      manage complex proxy configurations through a clean graphical interface.
    </p>
  </description>

  <screenshots>
    <screenshot type="default">
      <image>https://nyro.lol/assets/nyro-next-mobile.svg</image>
      <caption>Main Interface of Nyro</caption>
    </screenshot>
  </screenshots>

  <launchable type="desktop-id">nyro.desktop</launchable>

  <icon type="stock">nyro</icon>

  <categories>
    <category>Network</category>
  </categories>

  <keywords>
    <keyword>Nyro</keyword>
    <keyword>Proxy</keyword>
    <keyword>VPN</keyword>
    <keyword>V2Ray</keyword>
    <keyword>Nekoray</keyword>
    <keyword>Xray</keyword>
    <keyword>Psiphon</keyword>
    <keyword>OpenVPN</keyword>
  </keywords>

  <mime-types>
    <mime-type>x-scheme-handler/nyro</mime-type>
    <mime-type>x-scheme-handler/v2ray</mime-type>
    <mime-type>x-scheme-handler/v2rayn</mime-type>
    <mime-type>x-scheme-handler/v2rayng</mime-type>
    <mime-type>x-scheme-handler/clash</mime-type>
    <mime-type>x-scheme-handler/clashmeta</mime-type>
    <mime-type>x-scheme-handler/sing-box</mime-type>
  </mime-types>

  <url type="homepage">https://github.com/lucas04071403-web/nyro</url>
  <url type="bugtracker">https://github.com/lucas04071403-web/nyro/issues</url>
  <url type="help">https://github.com/lucas04071403-web/nyro</url>

  <provides>
    <binary>nyro</binary>
  </provides>

  <releases>
    <release version="1.0.1" date="2026-07-07">
      <description>
        <p>Add Xboard registration, plan purchase, and current plan status in subscriptions.</p>
      </description>
    </release>
    <release version="1.0.0" date="2026-07-07">
      <description>
        <p>Initial Linux release of Nyro with multi-protocol support and modern UI.</p>
      </description>
    </release>
  </releases>

  <translation type="gettext">nyro</translation>

  <custom>
    <value key="PackageName">nyro</value>
    <value key="Priority">optional</value>
    <value key="Section">x11</value>
    <value key="InstalledSize">6604</value>
    <value key="Essential">false</value>
  </custom>
</component>
